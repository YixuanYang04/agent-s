# Copy this file to .env on a Windows client, or let run_cli.bat create it.
# Keep real API keys only in .env. Do not commit .env.

# Main reasoning model. OPENAI_* names are also supported for compatibility.
AGENT_S_PROVIDER=openai
AGENT_S_MODEL=gpt-5.4
AGENT_S_MODEL_URL=https://aihubmix.com/v1
AGENT_S_MODEL_API_KEY=

# Compatibility names used by file_archive_watcher.py and older .bat files.
# You can either fill these, or leave them empty and fill AGENT_S_* above.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://aihubmix.com/v1
ARCHIVE_LLM_MODEL=gpt-5.4

# Remote UI-TARS grounding model through a local SSH tunnel.
AGENT_S_GROUND_PROVIDER=huggingface
AGENT_S_GROUND_URL=http://127.0.0.1:8000/v1
AGENT_S_GROUND_API_KEY=dummy-key
AGENT_S_GROUND_MODEL=UI-TARS-1.5-7B
AGENT_S_GROUNDING_WIDTH=1920
AGENT_S_GROUNDING_HEIGHT=1080

# Compatibility names used by older grounding config.
HF_ENDPOINT_URL=http://127.0.0.1:8000/v1
HF_TOKEN=dummy-key
GROUND_MODEL=UI-TARS-1.5-7B

# File auto-archive watcher. Used by run_file_archive_watcher.bat,
# run_archive_once.bat, and archive_feishu_once.py.
WATCH_DIR=%USERPROFILE%\Desktop\文件自动归档
ARCHIVE_ENABLE_FEISHU_AGENT=1
FEISHU_ARCHIVE_DOC_TITLE=文档归档处
FEISHU_TEST_KIND=发票
ARCHIVE_BATCH_SETTLE_SEC=8
ARCHIVE_BOOTSTRAP_EXISTING=1
ARCHIVE_AGENT_LOG_DIR=agent_execution_logs
# Optional comma-separated project whitelist, for example:
# ARCHIVE_PROJECT_NAMES=项目A,项目B,项目C
ARCHIVE_PROJECT_NAMES=
FEISHU_APP_PATH=C:\Users\tonyy\AppData\Local\Feishu\Feishu.exe
# Windows launcher behavior.
AGENT_S_USE_SSH_TUNNEL=1
AGENT_S_LOCAL_TUNNEL_PORT=8000
AGENT_S_FORCE_INSTALL=0
AGENT_S_MAX_AGENT_STEPS=8000

# SSH server that hosts the vLLM grounding model.
AGENT_S_REMOTE_HOST=111.0.130.56
AGENT_S_REMOTE_SSH_PORT=10023
AGENT_S_REMOTE_USER=lcwt
AGENT_S_REMOTE_VLLM_PORT=8000
AGENT_S_REMOTE_AUTO_START=1
AGENT_S_REMOTE_CONDA_ENV=vllm
AGENT_S_REMOTE_CUDA_VISIBLE_DEVICES=1,3
AGENT_S_REMOTE_MODEL_PATH=/mnt/data/Models/UI-TARS-1.5-7B
AGENT_S_REMOTE_TP_SIZE=2

# Optional. If set, the Windows launcher uses Python SSH forwarding and will
# not prompt for the server password.
AGENT_S_REMOTE_PASSWORD=
